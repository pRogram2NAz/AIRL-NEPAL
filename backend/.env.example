# Environment Variables for AIRL-Nepal Backend
# Copy this file to .env and fill in your real values
# NEVER commit .env to git

PORT=5000

# Set to "production" on your live server
NODE_ENV=development

# JWT Secret — use a long random string (32+ characters)
JWT_SECRET=replace_with_a_long_random_secret

# JWT expiry — e.g. 8h, 1d, 7d
JWT_EXPIRES_IN=8h

# Admin credentials
# To generate a bcrypt hash: node generate-hash.js yourPassword
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=replace_with_bcrypt_hash

# Database mode: "json" (simple file-based) or "mongodb"
DB_MODE=json

# MongoDB URI (only needed if DB_MODE=mongodb)
MONGO_URI=mongodb://localhost:27017/airl-nepal

# CORS — comma-separated list of allowed frontend origins
# Dev:        http://localhost:5500,http://localhost:8000
# Production: https://yourdomain.com
# NEVER use * in production
CORS_ORIGIN=http://localhost:5500,http://localhost:8000
